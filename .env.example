# ─── Netindavoid Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in all values before running docker compose up

# ── Postgres / TimescaleDB ─────────────────────────────────────────────────
POSTGRES_USER=netindavoid
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=netindavoid
DATABASE_URL=postgresql+asyncpg://netindavoid:changeme_strong_password@postgres:5432/netindavoid

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption (Fernet) ───────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=changeme_generate_with_fernet

# ── TOTP ──────────────────────────────────────────────────────────────────
TOTP_ISSUER_NAME=Netindavoid

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ── AI Service ────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:12b

# ── Router Agent ──────────────────────────────────────────────────────────
# OpenWrt router connection (configured per-user in Settings UI; these are defaults)
ROUTER_HOST=192.168.1.1
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=root
# Router SSH key or password stored encrypted via FERNET_KEY

# ── Network Scanning ──────────────────────────────────────────────────────
SCAN_NETWORK_CIDR=192.168.1.0/24
SCAN_INTERVAL_SECONDS=60
OUI_DB_PATH=/app/data/oui.txt

# ── Suricata ──────────────────────────────────────────────────────────────
SURICATA_EVE_LOG_PATH=/var/log/suricata/eve.json

# ── Pi-hole ───────────────────────────────────────────────────────────────
PIHOLE_API_URL=http://192.168.1.1/api
PIHOLE_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@netindavoid.local

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── Caddy / TLS ───────────────────────────────────────────────────────────
CADDY_DOMAIN=netindavoid.local
ACME_EMAIL=admin@example.com

# ── Single-tenant bootstrap ───────────────────────────────────────────────
ADMIN_EMAIL=admin@netindavoid.local
ADMIN_PASSWORD=changeme_admin_password
ADMIN_TENANT_NAME=Home Network
