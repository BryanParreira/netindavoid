<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.netindavoid.updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>PLACEHOLDER_APP_DIR/scripts/check-updates.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>PLACEHOLDER_APP_DIR/logs/updater.log</string>
    <key>StandardErrorPath</key>
    <string>PLACEHOLDER_APP_DIR/logs/updater.log</string>
    <key>WorkingDirectory</key>
    <string>PLACEHOLDER_APP_DIR</string>
</dict>
</plist>
