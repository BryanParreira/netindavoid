{
  "name": "vex",
  "version": "1.1.5",
  "description": "Network Security Monitoring Platform",
  "main": "main.js",
  "author": "Bryan Bernardo Parreira",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish always",
    "build:local": "electron-builder --mac --publish never",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vex.app",
    "productName": "Vex",
    "copyright": "Copyright \u00a9 2026 Bryan Bernardo Parreira",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "notarize.js",
      "beforeSign.js",
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web-out",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "Bryan Bernardo Parreira (5PNLAR99PK)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Vex ${version}",
      "background": null,
      "backgroundColor": "#111113",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 190,
          "type": "file"
        },
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "afterPack": "beforeSign.js",
    "afterSign": "notarize.js",
    "publish": {
      "provider": "github",
      "owner": "BryanParreira",
      "repo": "vex"
    },
    "generateUpdatesFilesForAllChannels": true
  }
}